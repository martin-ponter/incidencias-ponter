---
import "../styles/global.css";

const tipos = [
  { value: "email_office", label: "Problema con email de Office" },
  { value: "carpetas", label: "Problema con acceso a carpetas compartidas" },
  { value: "meetphone", label: "Problema con teléfono meetphone" },
  { value: "impresora", label: "Problema con impresora/escaner" },
  { value: "redes", label: "Problema con redes/internet" },
  { value: "config_usuario", label: "Problema con configuración de usuario" },
  { value: "remoto", label: "Problema con escritorio/servidor remoto" },
];

const prioridades = ["Baja", "Media", "Alta"];
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portal de incidencias Ponter</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/LogoPonter_Verde.png" />
  </head>

  <body class="min-h-screen bg-slate-100 text-slate-900">
    <main class="px-4 py-10">
      <div class="mx-auto max-w-3xl rounded-2xl bg-white p-6 shadow-lg md:p-8">
        
        <!-- HEADER -->
        <div class="mb-6">
          <h1 class="text-2xl font-bold md:text-3xl">
            Portal de incidencias
          </h1>

          <p class="mt-2 text-sm text-slate-600">
            Rellena el formulario y se enviará automáticamente al soporte correspondiente,
            con copia para ti y para el revisor interno.
          </p>

          <p class="mt-3 text-sm font-medium text-amber-700">
            * Si tu incidencia es con Quantum o con a3, debes abrir un ticket desde la aplicación.
          </p>

          <!-- aviso auth -->
          <p id="bitrix-status" class="mt-2 text-sm text-red-600 hidden">
            Debes acceder desde Bitrix para usar este formulario.
          </p>
        </div>

        <!-- FORM -->
        <form id="incidencia-form" class="space-y-4">

          <!-- NOMBRE + EMAIL -->
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="mb-1 block text-sm font-medium">
                Nombre completo *
              </label>
              <input
                id="nombre"
                name="nombre"
                type="text"
                required
                readonly
                class="w-full rounded-xl border border-slate-300 bg-slate-100 px-4 py-3 outline-none"
              />
            </div>

            <div>
              <label class="mb-1 block text-sm font-medium">
                Email corporativo *
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                readonly
                class="w-full rounded-xl border border-slate-300 bg-slate-100 px-4 py-3 outline-none"
              />
            </div>
          </div>

          <!-- TELEFONO + DEPARTAMENTO -->
          <div class="grid gap-4 md:grid-cols-2">
            <input id="telefono" name="telefono" placeholder="Teléfono" class="input" />
            <input id="departamento" name="departamento" placeholder="Departamento" class="input" />
          </div>

          <!-- TIPO -->
          <select id="tipo" name="tipo" required class="input">
            <option value="">Selecciona una opción</option>
            {tipos.map((t) => (
              <option value={t.value}>{t.label}</option>
            ))}
          </select>

          <!-- PRIORIDAD -->
          <select id="prioridad" name="prioridad" class="input">
            {prioridades.map((p) => (
              <option value={p}>{p}</option>
            ))}
          </select>

          <!-- ANYDESK -->
          <input id="anydesk" name="anydesk" placeholder="Número de AnyDesk" class="input" />

          <!-- ASUNTO -->
          <input id="asunto" name="asunto" placeholder="Asunto *" required class="input" />

          <!-- DESCRIPCIÓN -->
          <textarea id="descripcion" name="descripcion" rows="6" required class="input"></textarea>

          <!-- CHECK -->
          <div class="flex items-center gap-2">
            <input id="colectiva" name="colectiva" type="checkbox" />
            <label>Incidencia colectiva</label>
          </div>

          <!-- HONEYPOT -->
          <div class="hidden">
            <input id="website" name="website" type="text" />
          </div>

          <!-- BOTÓN -->
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button
              id="btn-enviar"
              type="submit"
              class="rounded-xl bg-slate-900 px-5 py-3 text-white"
            >
              Enviar incidencia
            </button>

            <p id="estado" class="text-sm"></p>
          </div>
        </form>
      </div>
    </main>

    <!-- BITRIX SDK -->
    <script src="https://api.bitrix24.com/api/v1/"></script>

    <script is:inline>
      const form = document.getElementById("incidencia-form");
      const estado = document.getElementById("estado");
      const boton = document.getElementById("btn-enviar");
      const status = document.getElementById("bitrix-status");

      let autorizado = false;

      // INIT BITRIX
      BX24.init(() => {
        BX24.callMethod("user.current", async (res) => {
          if (res.error()) {
            status.classList.remove("hidden");
            boton.disabled = true;
            return;
          }

          const user = res.data();

          document.getElementById("nombre").value =
            user.NAME + " " + user.LAST_NAME;

          document.getElementById("email").value = user.EMAIL;

          autorizado = true;

          // 🔐 sesión backend
          await fetch("/api/bitrix-auth", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              nombre: user.NAME + " " + user.LAST_NAME,
              email: user.EMAIL,
            }),
          });
        });
      });

      // SUBMIT
      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!autorizado) {
          estado.textContent = "No autorizado";
          estado.className = "text-red-600";
          return;
        }

        boton.disabled = true;
        boton.textContent = "Enviando...";

        const formData = new FormData(form);

        const payload = {
          telefono: formData.get("telefono"),
          departamento: formData.get("departamento"),
          tipo: formData.get("tipo"),
          prioridad: formData.get("prioridad"),
          asunto: formData.get("asunto"),
          descripcion: formData.get("descripcion"),
          anydesk: formData.get("anydesk"),
          colectiva: formData.get("colectiva") === "on",
          website: formData.get("website"),
        };

        try {
          const res = await fetch("/api/incidencia", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          const data = await res.json();

          if (!data.ok) throw new Error(data.error);

          estado.textContent = "Incidencia enviada ID: " + data.ticketId;
          estado.className = "text-green-700";

          form.reset();
        } catch (e) {
          estado.textContent = e.message;
          estado.className = "text-red-700";
        }

        boton.disabled = false;
        boton.textContent = "Enviar incidencia";
      });
    </script>

    <style>
      .input {
        width: 100%;
        border: 1px solid #cbd5f5;
        border-radius: 12px;
        padding: 12px;
      }
    </style>

  </body>
</html>