---
import "../styles/global.css";

const tipos = [
  { value: "email_office", label: "Problema con email de Office" },
  { value: "carpetas", label: "Problema con acceso a carpetas compartidas" },
  { value: "meetphone", label: "Problema con teléfono meetphone" },
  { value: "impresora", label: "Problema con impresora/escaner" },
  { value: "redes", label: "Problema con redes/internet" },
  { value: "config_usuario", label: "Problema con configuración de usuario" },
  { value: "remoto", label: "Problema con escritorio/servidor remoto" },
];

const prioridades = ["Baja", "Media", "Alta"];
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portal de incidencias Ponter</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/LogoPonter_Verde.png" />
  </head>

  <body class="min-h-screen bg-slate-100 text-slate-900">
    <main class="px-4 py-6 md:px-6 md:py-10">
      <div class="mx-auto max-w-3xl rounded-2xl bg-white p-5 shadow-lg md:p-8">
        <div class="mb-6">
          <div class="flex items-start gap-3">
            <img
              src="/LogoPonter_Verde.png"
              alt="Ponter"
              class="h-10 w-10 rounded-lg object-contain"
            />
            <div>
              <h1 class="text-2xl font-bold md:text-3xl">Portal de incidencias</h1>
              <p class="mt-2 text-sm text-slate-600">
                Rellena el formulario y se enviará automáticamente al soporte correspondiente,
                con copia para ti y para el revisor interno.
              </p>
              <p class="mt-3 text-sm font-medium text-amber-700">
                * Si tu incidencia es con Quantum o con a3, debes abrir un ticket desde la aplicación.
              </p>
            </div>
          </div>

          <div
            id="bitrix-status"
            class="mt-4 hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"
          >
            Debes acceder a este formulario desde Bitrix.
          </div>
        </div>

        <form id="incidencia-form" class="space-y-4">
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="nombre" class="mb-1 block text-sm font-medium">
                Nombre completo *
              </label>
              <input
                id="nombre"
                name="nombre"
                type="text"
                required
                readonly
                class="w-full rounded-xl border border-slate-300 bg-slate-100 px-4 py-3 text-slate-700 outline-none"
              />
            </div>

            <div>
              <label for="email" class="mb-1 block text-sm font-medium">
                Email corporativo *
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                readonly
                class="w-full rounded-xl border border-slate-300 bg-slate-100 px-4 py-3 text-slate-700 outline-none"
              />
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="telefono" class="mb-1 block text-sm font-medium">
                Teléfono de contacto
              </label>
              <input
                id="telefono"
                name="telefono"
                type="text"
                placeholder="Introduce tu teléfono"
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-slate-500"
              />
            </div>

            <div>
              <label for="departamento" class="mb-1 block text-sm font-medium">
                Departamento
              </label>
              <input
                id="departamento"
                name="departamento"
                type="text"
                placeholder="Introduce tu departamento"
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-slate-500"
              />
            </div>
          </div>

          <div>
            <label for="tipo" class="mb-1 block text-sm font-medium">
              Tipo de incidencia *
            </label>
            <select
              id="tipo"
              name="tipo"
              required
              class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-slate-500"
            >
              <option value="">Selecciona una opción</option>
              {tipos.map((t) => (
                <option value={t.value}>{t.label}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="prioridad" class="mb-1 block text-sm font-medium">
              Prioridad
            </label>
            <select
              id="prioridad"
              name="prioridad"
              class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-slate-500"
            >
              {prioridades.map((p) => (
                <option value={p}>{p}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="anydesk" class="mb-1 block text-sm font-medium">
              Número de AnyDesk
            </label>
            <input
              id="anydesk"
              name="anydesk"
              type="text"
              placeholder="Introduce el número de AnyDesk"
              class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-slate-500"
            />
          </div>

          <div>
            <label for="asunto" class="mb-1 block text-sm font-medium">
              Asunto *
            </label>
            <input
              id="asunto"
              name="asunto"
              type="text"
              required
              placeholder="Resume brevemente la incidencia"
              class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-slate-500"
            />
          </div>

          <div>
            <label for="descripcion" class="mb-1 block text-sm font-medium">
              Descripción *
            </label>
            <textarea
              id="descripcion"
              name="descripcion"
              rows="6"
              required
              placeholder="Describe la incidencia con el mayor detalle posible"
              class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-slate-500"
            ></textarea>
          </div>

          <div class="flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
            <input
              id="colectiva"
              name="colectiva"
              type="checkbox"
              class="h-4 w-4 rounded border-slate-300"
            />
            <label for="colectiva" class="text-sm font-medium text-slate-700">
              Incidencia colectiva
            </label>
          </div>

          <div class="hidden">
            <label for="website">Website</label>
            <input id="website" name="website" type="text" autocomplete="off" />
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button
              id="btn-enviar"
              type="submit"
              class="rounded-xl bg-slate-900 px-5 py-3 text-white transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60"
            >
              Enviar incidencia
            </button>

            <p id="estado" class="text-sm"></p>
          </div>
        </form>
      </div>
    </main>

    <script>
      import { initializeB24Frame } from "@bitrix24/b24jssdk";

      const form = document.getElementById("incidencia-form");
      const estado = document.getElementById("estado");
      const boton = document.getElementById("btn-enviar");
      const status = document.getElementById("bitrix-status");

      const nombreInput = document.getElementById("nombre");
      const emailInput = document.getElementById("email");

      let autorizado = false;

      async function inicializarBitrix() {
        try {
          const $b24 = await initializeB24Frame();
          const response = await $b24.callMethod("user.current", {});
          const user = response.getData().result;

          const nombre = [user.NAME, user.LAST_NAME].filter(Boolean).join(" ").trim();
          const email = user.EMAIL || "";

          if (!nombre || !email) {
            throw new Error("No se ha podido obtener el usuario de Bitrix.");
          }

          nombreInput.value = nombre;
          emailInput.value = email;

          const authRes = await fetch("/api/bitrix-auth", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              nombre,
              email,
            }),
          });

          const authData = await authRes.json();

          if (!authRes.ok || !authData.ok) {
            throw new Error(authData.error || "No se pudo validar la sesión de Bitrix.");
          }

          autorizado = true;
          status.classList.add("hidden");
        } catch (error) {
          console.error("Error inicializando Bitrix:", error);
          autorizado = false;
          boton.disabled = true;
          status.classList.remove("hidden");
          estado.textContent = "Acceso disponible solo desde Bitrix.";
          estado.className = "text-sm text-red-700";
        }
      }

      inicializarBitrix();

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!autorizado) {
          estado.textContent = "No autorizado";
          estado.className = "text-sm text-red-700";
          return;
        }

        estado.textContent = "";
        estado.className = "text-sm";
        boton.disabled = true;
        boton.textContent = "Enviando...";

        const formData = new FormData(form);

        const payload = {
          telefono: formData.get("telefono"),
          departamento: formData.get("departamento"),
          tipo: formData.get("tipo"),
          prioridad: formData.get("prioridad"),
          asunto: formData.get("asunto"),
          descripcion: formData.get("descripcion"),
          anydesk: formData.get("anydesk"),
          colectiva: formData.get("colectiva") === "on",
          website: formData.get("website"),
        };

        try {
          const res = await fetch("/api/incidencia", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          });

          const data = await res.json();

          if (!res.ok || !data.ok) {
            throw new Error(data.error || "No se pudo enviar la incidencia.");
          }

          estado.textContent = `Incidencia enviada correctamente. ID: ${data.ticketId}`;
          estado.className = "text-sm text-green-700";

          const nombreActual = nombreInput.value;
          const emailActual = emailInput.value;

          form.reset();

          nombreInput.value = nombreActual;
          emailInput.value = emailActual;
        } catch (error) {
          estado.textContent = error?.message || "Error al enviar la incidencia.";
          estado.className = "text-sm text-red-700";
        } finally {
          boton.disabled = false;
          boton.textContent = "Enviar incidencia";
        }
      });
    </script>
  </body>
</html>