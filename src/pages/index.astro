---
import "../styles/global.css";

const tipos = [
  { value: "office", label: "Problema con Office" },
  { value: "bitrix", label: "Problema con Bitrix" },
  { value: "hardware", label: "Problema de hardware" },
  { value: "correo", label: "Problema con correo" },
  { value: "otro", label: "Otro" },
];

const prioridades = ["Baja", "Media", "Alta"];
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portal de incidencias</title>
  </head>
  <body class="min-h-screen bg-slate-100 text-slate-900">
    <main class="px-4 py-10">
      <div class="mx-auto max-w-3xl rounded-2xl bg-white p-6 shadow-lg md:p-8">
        <div class="mb-6">
          <h1 class="text-2xl font-bold md:text-3xl">Portal de incidencias</h1>
          <p class="mt-2 text-sm text-slate-600">
            Rellena el formulario y se enviará automáticamente al soporte correspondiente,
            con copia para ti y para el revisor interno.
          </p>
        </div>

        <form id="incidencia-form" class="space-y-4">
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="nombre" class="mb-1 block text-sm font-medium">Nombre completo *</label>
              <input
                id="nombre"
                name="nombre"
                type="text"
                required
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-slate-500"
              />
            </div>

            <div>
              <label for="email" class="mb-1 block text-sm font-medium">Email corporativo *</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-slate-500"
              />
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="departamento" class="mb-1 block text-sm font-medium">Departamento</label>
              <input
                id="departamento"
                name="departamento"
                type="text"
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-slate-500"
              />
            </div>

            <div>
              <label for="tipo" class="mb-1 block text-sm font-medium">Tipo de incidencia *</label>
              <select
                id="tipo"
                name="tipo"
                required
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-slate-500"
              >
                <option value="">Selecciona una opción</option>
                {tipos.map((tipo) => (
                  <option value={tipo.value}>{tipo.label}</option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label for="prioridad" class="mb-1 block text-sm font-medium">Prioridad</label>
            <select
              id="prioridad"
              name="prioridad"
              class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-slate-500"
            >
              {prioridades.map((prioridad) => (
                <option value={prioridad}>{prioridad}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="asunto" class="mb-1 block text-sm font-medium">Asunto *</label>
            <input
              id="asunto"
              name="asunto"
              type="text"
              required
              class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-slate-500"
            />
          </div>

          <div>
            <label for="descripcion" class="mb-1 block text-sm font-medium">Descripción *</label>
            <textarea
              id="descripcion"
              name="descripcion"
              required
              rows="7"
              class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-slate-500"
            ></textarea>
          </div>

          <div class="hidden">
            <label for="website">Website</label>
            <input id="website" name="website" type="text" autocomplete="off" />
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button
              id="btn-enviar"
              type="submit"
              class="rounded-xl bg-slate-900 px-5 py-3 text-white transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60"
            >
              Enviar incidencia
            </button>

            <p id="estado" class="text-sm"></p>
          </div>
        </form>
      </div>
    </main>

    <script is:inline>
      const form = document.getElementById("incidencia-form");
      const estado = document.getElementById("estado");
      const boton = document.getElementById("btn-enviar");

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        estado.textContent = "";
        estado.className = "text-sm";
        boton.disabled = true;
        boton.textContent = "Enviando...";

        const formData = new FormData(form);

        const payload = {
          nombre: formData.get("nombre"),
          email: formData.get("email"),
          departamento: formData.get("departamento"),
          tipo: formData.get("tipo"),
          prioridad: formData.get("prioridad"),
          asunto: formData.get("asunto"),
          descripcion: formData.get("descripcion"),
          website: formData.get("website"),
        };

        try {
          const res = await fetch("/api/incidencia", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          });

          const data = await res.json();

          if (!res.ok || !data.ok) {
            throw new Error(data.error || "No se pudo enviar la incidencia.");
          }

          estado.textContent = `Incidencia enviada correctamente. ID: ${data.ticketId}`;
          estado.className = "text-sm text-green-700";
          form.reset();
        } catch (error) {
          estado.textContent = error?.message || "Error al enviar la incidencia.";
          estado.className = "text-sm text-red-700";
        } finally {
          boton.disabled = false;
          boton.textContent = "Enviar incidencia";
        }
      });
    </script>
  </body>
</html>