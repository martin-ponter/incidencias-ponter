---
import "../styles/global.css";

const tipos = [
  { value: "email_office", label: "Problema con email de Office" },
  { value: "carpetas", label: "Problema con acceso a carpetas compartidas" },
  { value: "meetphone", label: "Problema con teléfono meetphone" },
  { value: "impresora", label: "Problema con impresora/escaner" },
  { value: "redes", label: "Problema con redes/internet" },
  { value: "config_usuario", label: "Problema con configuración de usuario" },
  { value: "remoto", label: "Problema con escritorio/servidor remoto" },
];

const prioridades = ["Baja", "Media", "Alta"];
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portal incidencias</title>
</head>

<body class="min-h-screen bg-slate-100">

<main class="px-4 py-10">
<div class="mx-auto max-w-3xl bg-white p-6 rounded-xl">

<h1 class="text-2xl font-bold">Portal incidencias</h1>

<p class="text-sm text-amber-700 mt-2">
* Si tu incidencia es con Quantum o con a3, abre ticket desde la aplicación
</p>

<form id="incidencia-form" class="space-y-4 mt-6">

<input id="nombre" name="nombre" readonly class="input"/>
<input id="email" name="email" readonly class="input"/>

<input id="telefono" name="telefono" placeholder="Teléfono" class="input"/>
<input id="departamento" name="departamento" placeholder="Departamento" class="input"/>

<select id="tipo" name="tipo" required class="input">
<option value="">Selecciona</option>
{tipos.map(t => <option value={t.value}>{t.label}</option>)}
</select>

<select id="prioridad" name="prioridad" class="input">
{prioridades.map(p => <option>{p}</option>)}
</select>

<input id="anydesk" name="anydesk" placeholder="AnyDesk" class="input"/>

<input id="asunto" name="asunto" placeholder="Asunto" required class="input"/>

<textarea id="descripcion" name="descripcion" required class="input"></textarea>

<button id="btn-enviar">Enviar</button>

<p id="estado"></p>

</form>
</div>
</main>

<!-- SDK BITRIX -->
<script src="https://api.bitrix24.com/api/v1/"></script>

<script is:inline>

const estado = document.getElementById("estado");
const boton = document.getElementById("btn-enviar");

// 🔐 INIT BITRIX
BX24.init(async function () {

  try {
    // 👤 obtener usuario
    BX24.callMethod('user.current', async function(res){

      if(res.error()){
        estado.textContent = "Error obteniendo usuario Bitrix";
        return;
      }

      const user = res.data();

      // autofill
      document.getElementById("nombre").value =
        `${user.NAME} ${user.LAST_NAME}`;

      document.getElementById("email").value = user.EMAIL;

      // 🔐 crear sesión backend
      await fetch("/api/bitrix-auth", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          nombre: `${user.NAME} ${user.LAST_NAME}`,
          email: user.EMAIL
        })
      });

    });

  } catch(e){
    estado.textContent = "No estás dentro de Bitrix";
  }

});


// 🚀 envío form
document.getElementById("incidencia-form").addEventListener("submit", async (e) => {
  e.preventDefault();

  boton.disabled = true;

  const formData = new FormData(e.target);

  const payload = Object.fromEntries(formData.entries());
  payload.colectiva = formData.get("colectiva") === "on";

  try {
    const res = await fetch("/api/incidencia", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(payload),
    });

    const data = await res.json();

    if(!data.ok) throw new Error(data.error);

    estado.textContent = "OK ID: " + data.ticketId;

  } catch(err){
    estado.textContent = err.message;
  }

  boton.disabled = false;
});

</script>

</body>
</html>